# API (apps/api)
# Supabase → Project Settings → Database → database password
SUPABASE_DB_PASSWORD=your-database-password

# Optional: paste full URI instead (overrides auto-built URL when not localhost)
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

JWT_SECRET=change-me-in-production
ML_ENGINE_URL=http://localhost:8000
PORT=3001

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_DB_HOST=aws-0-REGION.pooler.supabase.com

# Local Postgres alternative (Docker)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shiftagent
# SUPABASE_DB_PASSWORD=

# Clearview (mock until manager provides real keys)
CLEARVIEW_MODE=mock
CLEARVIEW_CLIENT_ID=dummy_client_id
CLEARVIEW_CLIENT_SECRET=dummy_client_secret
CLEARVIEW_API_BASE_URL=https://mock.clearview.local
CLEARVIEW_REDIRECT_URI=http://localhost:3001/api/clearview/callback

CRON_SECRET=dev-cron-secret
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Web (apps/web)
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Mobile (apps/mobile) — use your LAN IP on a physical device, e.g. http://192.168.1.10:3001/api
# Android emulator uses 10.0.2.2 automatically if localhost is set
EXPO_PUBLIC_API_URL=http://localhost:3001/api
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
