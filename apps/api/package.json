{
  "name": "@shiftagent/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "tsc -p ../../packages/shared/tsconfig.json",
    "predev": "tsc -p ../../packages/shared/tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed-restaurant": "tsx src/scripts/seedRestaurantRoster.ts",
    "db:setup-schedule-demo": "tsx src/scripts/setupScheduleDemo.ts",
    "db:import-sales": "tsx src/scripts/importDropChartSales.ts",
    "db:import-clearview-sales": "cd ../ml-engine && python3 import_clearview_sales.py",
    "db:import-lsl-schedules": "tsx src/scripts/importLslSchedulePdfs.ts",
    "db:train-lsl-prior": "cd ../ml-engine && python3 train_historical.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@shiftagent/shared": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "openai": "^6.41.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "pg-mem": "^3.0.5",
    "rate-limit-redis": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
