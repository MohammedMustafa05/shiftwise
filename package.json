{
  "name": "shiftwise",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered restaurant scheduling platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:web": "npm run dev -w @shiftwise/web",
    "dev:api": "npm run dev -w @shiftwise/api",
    "dev:mobile": "npm run dev -w @shiftwise/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  }
}
