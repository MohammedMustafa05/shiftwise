{
  "name": "shiftagent",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered restaurant scheduling platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:web": "npm run dev -w @shiftagent/web",
    "dev:api": "npm run dev -w @shiftagent/api",
    "dev:ml": "cd apps/ml-engine && uvicorn main:app --reload --port 8000",
    "dev:stack": "bash scripts/dev-stack.sh",
    "dev:mobile": "npm run dev -w @shiftagent/mobile",
    "dev:mobile:ios": "npm run ios -w @shiftagent/mobile",
    "dev:mobile:android": "npm run android -w @shiftagent/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test:api": "npm run test -w @shiftagent/api",
    "test:ml": "cd apps/ml-engine && python -m pytest",
    "db:migrate": "npm run db:migrate -w @shiftagent/api",
    "db:seed": "npm run db:seed -w @shiftagent/api",
    "db:seed-restaurant": "npm run db:seed-restaurant -w @shiftagent/api",
    "db:setup-schedule-demo": "npm run db:setup-schedule-demo -w @shiftagent/api",
    "db:import-sales": "npm run db:import-sales -w @shiftagent/api"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "expo": "~56.0.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-web": "^0.21.2"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  }
}
